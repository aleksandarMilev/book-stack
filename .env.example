SA_PASSWORD=sa-pass
APP_SECRET=A_very_strong_secret_key_that_is_at_least_16_characters_long
ISSUER=BookStack
AUDIENCE=BookStackClient
DB_NAME=MyDb
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=BookStack <no-reply@yourdomain.com>
SMTP_USE_SSL=false
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Browser-facing frontend API base URL for local Docker dev.
# Use IPv4 loopback to avoid localhost (::1) hangs on some Windows setups.
VITE_REACT_APP_SERVER_URL=http://127.0.0.1:8080
